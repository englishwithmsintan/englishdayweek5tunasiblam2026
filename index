                            <p style="font-family: 'Fredoka', sans-serif; color: var(--red); margin-bottom: var(--space-sm); text-align: center;">🎯 Challenge: Fact Checker Questions</p>
                            <ul style="list-style: none; padding: 0; text-align: center; font-size: var(--font-lg);">
                                <li>❓ "Who said that?"</li>
                                <li>❓ "Is that true?"</li>
                                <li>❓ "Where exactly did it happen?"</li>
                            </ul>
                        </div>
                    </div>

                    <div class="worksheet">
                        <div class="worksheet-header">
                            <div class="worksheet-title">📋 Self-Assessment</div>
                            <div style="color: #666; font-size: var(--font-md);">Upper Grades - Unit 5</div>
                        </div>
                        <div style="display: grid; gap: 20px;">
                            <div>
                                <strong style="font-family: 'Fredoka', sans-serif;">I feel:</strong>
                                <div style="margin-top: 10px; display: flex; gap: 15px; flex-wrap: wrap;">
                                    <label style="background: #f0f0f0; padding: 8px 15px; border-radius: 20px; cursor: pointer;">
                                        <input type="checkbox" style="margin-right: 8px;"> 😶 Shy
                                    </label>
                                    <label style="background: #f0f0f0; padding: 8px 15px; border-radius: 20px; cursor: pointer;">
                                        <input type="checkbox" style="margin-right: 8px;"> 🙂 Okay
                                    </label>
                                    <label style="background: #f0f0f0; padding: 8px 15px; border-radius: 20px; cursor: pointer;">
                                        <input type="checkbox" style="margin-right: 8px;"> 😄 Confident
                                    </label>
                                </div>
                            </div>
                            <div>
                                <strong style="font-family: 'Fredoka', sans-serif;">Reporting verbs I used (circle):</strong>
                                <div style="margin-top: 15px; display: flex; gap: 10px; flex-wrap: wrap; font-family: 'Fredoka', sans-serif;">
                                    <span style="border: 2px solid #333; padding: 5px 15px; border-radius: 20px;">said</span>
                                    <span style="border: 2px solid #333; padding: 5px 15px; border-radius: 20px;">told</span>
                                    <span style="border: 2px solid #333; padding: 5px 15px; border-radius: 20px;">explained</span>
                                    <span style="border: 2px solid #333; padding: 5px 15px; border-radius: 20px;">claimed</span>
                                    <span style="border: 2px solid #333; padding: 5px 15px; border-radius: 20px;">mentioned</span>
                                </div>
                            </div>
                            <div>
                                <strong style="font-family: 'Fredoka', sans-serif;">One interesting fact I reported:</strong>
                                <div class="worksheet-line" contenteditable="true" style="min-height: 60px; margin-top: 10px; background: #f9f9f9; padding: 10px; border-radius: 8px;"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <button class="activity-btn" onclick="celebrate()" style="margin-top: var(--space-lg);">
                    🎉 Celebrate Our News Broadcast!
                </button>
            </div>
        </section>
    </div>

    <script>
        // Tab Navigation
        function showSection(sectionId) {
            document.querySelectorAll('.content-section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById(sectionId).classList.add('active');
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.closest('.tab-btn').classList.add('active');
            
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        // Grade Toggles
        function toggleGoal(grade) {
            document.getElementById('goal-lower').style.display = grade === 'lower' ? 'block' : 'none';
            document.getElementById('goal-upper').style.display = grade === 'upper' ? 'block' : 'none';
            updateToggleButtons(event.target);
        }

        function toggleVocab(grade) {
            document.getElementById('vocab-lower').style.display = grade === 'lower' ? 'grid' : 'none';
            document.getElementById('vocab-upper').style.display = grade === 'upper' ? 'grid' : 'none';
            updateToggleButtons(event.target);
        }

        function togglePractice(grade) {
            document.getElementById('practice-lower').style.display = grade === 'lower' ? 'block' : 'none';
            document.getElementById('practice-upper').style.display = grade === 'upper' ? 'block' : 'none';
            updateToggleButtons(event.target);
        }

        function toggleShare(grade) {
            document.getElementById('share-lower-content').style.display = grade === 'lower' ? 'block' : 'none';
            document.getElementById('share-upper-content').style.display = grade === 'upper' ? 'block' : 'none';
            updateToggleButtons(event.target);
        }

        function updateToggleButtons(clicked) {
            clicked.parentElement.querySelectorAll('.grade-btn').forEach(btn => btn.classList.remove('active'));
            clicked.classList.add('active');
        }

        // Case Selection
        let selectedCase = null;
        function selectCase(card, caseType) {
            document.querySelectorAll('.case-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');
            selectedCase = caseType;
            
            // Auto-fill some hints based on case
            if (caseType === 'pe') {
                document.getElementById('lg-answer-1').value = "P.E. class was cancelled";
                document.getElementById('lg-feeling').value = "sad";
            } else if (caseType === 'homework') {
                document.getElementById('lg-answer-1').value = "there is no homework today";
                document.getElementById('lg-feeling').value = "happy";
            } else if (caseType === 'book') {
                document.getElementById('lg-answer-1').value = "he found his lost book in the library";
                document.getElementById('lg-feeling').value = "relieved";
            }
        }

        // Vocabulary Cards
        function flipCard(card) {
            card.classList.toggle('flipped');
        }

        // Reporting Verbs Selection
        function toggleVerb(btn) {
            btn.classList.toggle('selected');
        }

        // Generate Lower Grades Report
        function generateLowerReport() {
            const what = document.getElementById('lg-answer-1').value || "(what happened)";
            const feeling = document.getElementById('lg-feeling').value || "(feeling)";
            
            const report = `The witness said that ${what}. He/She felt ${feeling}.`;
            document.getElementById('lg-report-text').textContent = report;
            document.getElementById('lg-final-report').style.display = 'block';
            
            // Update inline preview
            document.getElementById('lg-report-1').textContent = what;
            
            celebrate();
        }

        function resetLowerForm() {
            document.getElementById('lg-answer-1').value = '';
            document.getElementById('lg-feeling').value = '';
            document.getElementById('lg-report-text').textContent = '';
            document.getElementById('lg-final-report').style.display = 'none';
            document.getElementById('lg-report-1').textContent = '(what happened)';
            document.querySelectorAll('.case-card').forEach(c => c.classList.remove('selected'));
        }

        // Generate Upper Grades Report
        function generateUpperReport() {
            const what = document.getElementById('ug-what').value;
            const when = document.getElementById('ug-when').value;
            const where = document.getElementById('ug-where').value;
            const how = document.getElementById('ug-how').value;
            
            const selectedVerbs = Array.from(document.querySelectorAll('.verb-btn.selected')).map(b => b.textContent);
            const verb1 = selectedVerbs[0] || 'explained';
            const verb2 = selectedVerbs[1] || 'mentioned';
            
            const report = `The witness ${verb1} that ${what}. It happened ${when} ${where}. The witness ${verb2} that ${how}.`;
            
            document.getElementById('ug-report-text').textContent = report;
            document.getElementById('ug-final-report').style.display = 'block';
            
            celebrate();
        }

        function resetUpperForm() {
            document.getElementById('ug-what').value = '';
            document.getElementById('ug-when').value = '';
            document.getElementById('ug-where').value = '';
            document.getElementById('ug-how').value = '';
            document.getElementById('ug-report-text').textContent = '';
            document.getElementById('ug-final-report').style.display = 'none';
            document.querySelectorAll('.verb-btn').forEach(b => b.classList.remove('selected'));
            document.querySelectorAll('.case-card').forEach(c => c.classList.remove('selected'));
        }

        // Text to Speech
        function speakText(text) {
            if ('speechSynthesis' in window) {
                const utterance = new SpeechSynthesisUtterance(text);
                utterance.rate = 0.8;
                utterance.pitch = 1.1;
                speechSynthesis.speak(utterance);
            }
        }

        // Emoji Selection for Assessment
        function selectEmoji(emoji) {
            emoji.parentElement.querySelectorAll('span').forEach(e => e.style.opacity = '0.5');
            emoji.style.opacity = '1';
            emoji.style.transform = 'scale(1.3)';
        }

        // Celebration Effect
        function celebrate() {
            const colors = ['#5865F2', '#eb459e', '#3ba55d', '#faa81a', '#ed4245', '#00d4aa'];
            for (let i = 0; i < 50; i++) {
                setTimeout(() => {
                    const confetti = document.createElement('div');
                    confetti.className = 'confetti';
                    confetti.style.left = Math.random() * 100 + 'vw';
                    confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                    confetti.style.animationDuration = (Math.random() * 2 + 2) + 's';
                    confetti.style.borderRadius = Math.random() > 0.5 ? '50%' : '0';
                    document.body.appendChild(confetti);
                    setTimeout(() => confetti.remove(), 3000);
                }, i * 30);
            }
        }

        // Verb Practice Game
        function startVerbPractice() {
            const verbs = ['said', 'told', 'explained', 'mentioned', 'claimed'];
            const sentences = [
                "He _____ that he was sick.",
                "She _____ me the answer.",
                "The teacher _____ the lesson clearly.",
                "He _____ that he saw everything."
            ];
            const randomIdx = Math.floor(Math.random() * sentences.length);
            alert(`🎭 Fill in the blank:\n\n"${sentences[randomIdx]}"\n\nChoose from: ${verbs.join(', ')}`);
        }

        // Timer - 40 minutes for this session
        let timeLeft = 1800; // 30 minutes
        const timerElement = document.getElementById('timer');
        
        function updateTimer() {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            timerElement.textContent = `${minutes}:${seconds.toString().padStart(2, '0')}`;
            
            if (timeLeft <= 300) { // 5 minutes warning
                timerElement.style.color = 'var(--red)';
            }
            
            if (timeLeft > 0) {
                timeLeft--;
                setTimeout(updateTimer, 1000);
            } else {
                timerElement.style.color = 'var(--red)';
                alert('⏰ Time\'s up! Great reporting today!');
            }
        }
        
        // Start timer when page loads
        updateTimer();

        // Keyboard shortcuts
        document.addEventListener('keydown', (e) => {
            if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
            if (e.key === '1') document.querySelector('.tab-btn:nth-child(1)').click();
            if (e.key === '2') document.querySelector('.tab-btn:nth-child(2)').click();
            if (e.key === '3') document.querySelector('.tab-btn:nth-child(3)').click();
            if (e.key === '4') document.querySelector('.tab-btn:nth-child(4)').click();
        });
    </script>
</body>
</html>
